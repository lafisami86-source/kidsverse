generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// NextAuth models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id               String    @id @default(cuid())
  name             String?
  email            String    @unique
  emailVerified    DateTime?
  image            String?
  password         String?   // Hashed password for credential auth (null for OAuth users)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  accounts         Account[]
  sessions         Session[]
  childProfiles    ChildProfile[]
  subscription     Subscription?
}

model ChildProfile {
  id              String   @id @default(cuid())
  name            String
  age             Int
  avatar          String   @default("default-avatar")
  ageGroup        String   // "toddler" | "early" | "kid"
  screenTimeLimit Int      @default(60) // minutes per day
  contentFilter   String   @default("all") // content category restrictions
  parentId        String

  parent          User     @relation(fields: [parentId], references: [id], onDelete: Cascade)
  progresses      Progress[]
  badges          Badge[]
  gameScores      GameScore[]
  drawings        Drawing[]
  favoriteStories FavoriteStory[]

  @@index([parentId])
}

model Progress {
  id          String   @id @default(cuid())
  childId     String
  moduleId    String   // "alphabet" | "numbers" | "colors" | "science"
  lessonId    String
  completed   Boolean  @default(false)
  score       Int      @default(0)
  stars       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  child       ChildProfile @relation(fields: [childId], references: [id], onDelete: Cascade)

  @@unique([childId, moduleId, lessonId])
  @@index([childId])
  @@index([moduleId])
}

model Badge {
  id          String   @id @default(cuid())
  childId     String
  type        String   // badge category
  name        String
  description String
  icon        String
  earnedAt    DateTime @default(now())

  child       ChildProfile @relation(fields: [childId], references: [id], onDelete: Cascade)

  @@unique([childId, type])
  @@index([childId])
}

model GameScore {
  id          String   @id @default(cuid())
  childId     String
  gameType    String   // "memory" | "puzzle" | "spelling" | "math"
  score       Int
  level       Int      @default(1)
  duration    Int      @default(0) // seconds
  completedAt DateTime @default(now())

  child       ChildProfile @relation(fields: [childId], references: [id], onDelete: Cascade)

  @@index([childId, gameType])
}

model Drawing {
  id               String   @id @default(cuid())
  childId          String
  title            String
  imageUrl         String
  cloudinaryPublicId String?
  createdAt        DateTime @default(now())

  child            ChildProfile @relation(fields: [childId], references: [id], onDelete: Cascade)

  @@index([childId])
}

model FavoriteStory {
  id       String @id @default(cuid())
  childId  String
  storyId  String
  addedAt  DateTime @default(now())

  child    ChildProfile @relation(fields: [childId], references: [id], onDelete: Cascade)

  @@unique([childId, storyId])
  @@index([childId])
}

model Subscription {
  id                String    @id @default(cuid())
  userId            String    @unique
  stripeCustomerId  String?
  stripePriceId     String?
  stripeSubscriptionId String?
  status            String    @default("free") // "free" | "active" | "canceled" | "past_due"
  plan              String    @default("free") // "free" | "premium"
  currentPeriodEnd  DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}
